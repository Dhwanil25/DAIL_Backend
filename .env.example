# =============================================================================
# DAIL Backend - Environment Configuration
# =============================================================================
# Copy to .env and fill in your values.

# Application
APP_NAME=DAIL
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://dail_user:dail_secret_changeme@db:5432/dail
DATABASE_URL_SYNC=postgresql://dail_user:dail_secret_changeme@db:5432/dail

# AI / LLM Keys  (leave blank to disable AI endpoints)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL=INFO
